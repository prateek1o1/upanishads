{
  "id": "mundaka",
  "name": "Mundaka Upanishad",
  "name_sanskrit": "मुण्डकोपनिषद्",
  "tradition": "Atharvaveda",
  "summary": "The Mundaka Upanishad distinguishes between the lower knowledge (apara vidya — sciences, rituals) and the higher knowledge (para vidya — knowledge of Brahman). It teaches that Brahman is the source of all, like sparks from fire, and can only be known through a qualified teacher.",
  "total_verses": 64,
  "verses": [
    {
      "upanishad": "mundaka",
      "verse_number": 1,
      "tags": [
        "para vidya",
        "apara vidya",
        "two knowledges"
      ],
      "sanskrit": "द्वे विद्ये वेदितव्ये इति ह स्म यद्ब्रह्मविदो वदन्ति परा चैवापरा च ||१.१.४||",
      "transliteration": "dve vidye veditavye iti ha sma yad brahmavido vadanti parā caivāparā ca ||1.1.4||",
      "word_meanings": [
        {
          "word": "द्वे विद्ये",
          "meaning": "two knowledges"
        },
        {
          "word": "वेदितव्ये",
          "meaning": "to be known"
        },
        {
          "word": "ब्रह्मविदः",
          "meaning": "knowers of Brahman"
        },
        {
          "word": "परा",
          "meaning": "higher (knowledge of Brahman)"
        },
        {
          "word": "अपरा",
          "meaning": "lower (all other sciences)"
        }
      ],
      "english_translation": "Two kinds of knowledge are to be known — so say the knowers of Brahman — the higher and the lower.",
      "shankara_bhashya_sanskrit": "परा — ब्रह्मज्ञानम्। अपरा — ऋग्वेदादिचतुर्वेदाः सशिक्षाव्याकरणादयश्च।",
      "shankara_bhashya_english": "Shankara: The higher knowledge is the direct knowledge of Brahman. The lower knowledge comprises the four Vedas along with their six auxiliaries — phonetics, ritual, grammar, etymology, metre, and astronomy."
    },
